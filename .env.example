# Admin Authentication
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=YourStrongPassword123!
ADMIN_SECRET_TOKEN=generate-a-long-random-string-here-at-least-32-chars

# MongoDB Atlas (required for product management)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/craftlyaura?retryWrites=true&w=majority

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Backend Chat Server
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
